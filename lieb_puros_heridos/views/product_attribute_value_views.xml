<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="product_attribute_value_form_lieb" model="ir.ui.view">
        <field name="name">product.attribute.value.form.lieb</field>
        <field name="model">product.attribute</field>
        <field name="inherit_id" ref="product.product_attribute_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='value_ids']/list" position="inside">
                <field name="discount_percent" string="% Descuento" optional="show"/>
            </xpath>
        </field>
    </record>

</odoo>
