<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!--
            Tabaco para Pipa: producto independiente resultado del proceso de picado.
            UdM en gramos, rastreado por lote para vincular cada lote con el acta
            de clasificación / hoja de salida de origen.
            No se compra directamente (purchase_ok=False); el stock entra vía
            recepción manual del proveedor de picado referenciando el lote origen.
        -->
        <record id="product_template_tabaco_pipa" model="product.template">
            <field name="name">Tabaco para Pipa</field>
            <field name="type">consu</field>
            <field name="categ_id" ref="product_category_tabaco_pipa"/>
            <field name="uom_id" ref="uom.product_uom_gram"/>
            <field name="uom_po_id" ref="uom.product_uom_gram"/>
            <field name="tracking">lot</field>
            <field name="sale_ok" eval="True"/>
            <field name="purchase_ok" eval="False"/>
        </record>

    </data>
</odoo>
